#!/usr/bin/env bash
# Whetstone: Claude via Headroom; rtk subcommand keeps ANTHROPIC_BASE_URL.
set -euo pipefail

DEFAULT_PROXY="http://127.0.0.1:8787"
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-$DEFAULT_PROXY}"
WHETSTONE_HOME="${WHETSTONE_HOME:-$HOME/.whetstone}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCAL_VERSION_FILE="${WHETSTONE_VERSION_FILE:-$WHETSTONE_HOME/VERSION}"
FALLBACK_VERSION_FILE="$SCRIPT_DIR/../VERSION"
REMOTE_VERSION_URL="${WHETSTONE_REMOTE_VERSION_URL:-\
https://raw.githubusercontent.com/z19r/whetstone/main/VERSION}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/whetstone"
UPDATE_CACHE_FILE="$CACHE_DIR/update-check"
UPDATE_CHECK_TTL_SECONDS="${WHETSTONE_UPDATE_TTL_SECONDS:-43200}"
WHETSTONE_VERSION="dev"

# Pin Claude Code to Opus 4.6 unless the caller passes --model.
DEFAULT_CLAUDE_MODEL="claude-opus-4-6"

if [[ -f "$LOCAL_VERSION_FILE" ]]; then
    WHETSTONE_VERSION="$(tr -d '[:space:]' < "$LOCAL_VERSION_FILE")"
elif [[ -f "$FALLBACK_VERSION_FILE" ]]; then
    WHETSTONE_VERSION="$(tr -d '[:space:]' < "$FALLBACK_VERSION_FILE")"
fi

extract_semver() {
    local raw="$1"
    local match
    match=$(echo "$raw" | sed -nE 's/.*([0-9]+\.[0-9]+\.[0-9]+).*/\1/p')
    echo "$match"
}

version_lt() {
    local left="$1"
    local right="$2"
    if [[ -z "$left" || -z "$right" ]]; then
        return 1
    fi
    [[ "$(printf '%s\n%s\n' "$left" "$right" | sort -V | head -n1)" \
        != "$right" ]]
}

print_version() {
    echo "whetstone $WHETSTONE_VERSION"
}

run_self_update() {
    local installer="$WHETSTONE_HOME/install.sh"
    if [[ ! -f "$installer" ]]; then
        echo "whetstone: missing installer at $installer" >&2
        echo "hint: reinstall from z19r/whetstone first." >&2
        exit 1
    fi
    exec bash "$installer"
}

check_for_updates() {
    if [[ "${WHETSTONE_NO_UPDATE_CHECK:-0}" == "1" ]]; then
        return 0
    fi
    if ! command -v curl &>/dev/null; then
        return 0
    fi

    mkdir -p "$CACHE_DIR"
    local now last_check
    now=$(date +%s)
    if [[ -f "$UPDATE_CACHE_FILE" ]]; then
        last_check="$(cut -d' ' -f1 "$UPDATE_CACHE_FILE" 2>/dev/null || \
            echo 0)"
    else
        last_check=0
    fi

    if (( now - last_check < UPDATE_CHECK_TTL_SECONDS )); then
        return 0
    fi

    local remote_raw remote_version local_version
    remote_raw=$(curl -fsSL --max-time 2 "$REMOTE_VERSION_URL" \
        2>/dev/null || true)
    remote_version="$(extract_semver "$remote_raw")"
    local_version="$(extract_semver "$WHETSTONE_VERSION")"

    printf '%s %s\n' "$now" "${remote_version:-unknown}" \
        > "$UPDATE_CACHE_FILE"

    if version_lt "$local_version" "$remote_version"; then
        echo "[whetstone] update available: $local_version -> " \
            "$remote_version" >&2
        echo "[whetstone] run: whetstone update" >&2
    fi
}

has_user_model_flag() {
    local a
    for a in "$@"; do
        case "$a" in
            --model|--model=*)
                return 0
                ;;
        esac
    done
    return 1
}

wrap_claude() {
    if has_user_model_flag "$@"; then
        exec headroom wrap claude "$@"
    fi
    exec headroom wrap claude --model "$DEFAULT_CLAUDE_MODEL" "$@"
}

usage() {
    cat <<'USAGE'
Whetstone — Headroom + RTK helpers for Claude Code

  whetstone                 headroom wrap claude (default model: Opus 4.6)
  whetstone claude [args]   headroom wrap claude [args]
  whetstone proxy [args]    headroom proxy [args]
  whetstone rtk [args]      rtk [args] (API traffic via Headroom URL)
  whetstone version         print installed whetstone version
  whetstone update          pull latest + rerun setup in this project
  whetstone help            this message

Also: whetstone-rtk — same as whetstone rtk (PATH entry).

Pass Headroom/Claude args only after 'claude' or 'code', e.g.
  whetstone claude --your-flags
USAGE
}

unknown_cmd() {
    local bad="$1"
    echo "whetstone: unknown command: ${bad}" >&2
    if [[ "${bad}" == wrap ]]; then
        echo "hint: use 'whetstone' or 'whetstone claude [args]', not" \
            "'whetstone wrap ...'." >&2
    fi
    usage >&2
    exit 1
}

main() {
    check_for_updates

    if [[ $# -eq 0 ]]; then
        wrap_claude
    fi
    case "$1" in
        -h|--help|help)
            usage
            ;;
        version|--version|-v)
            print_version
            ;;
        update|self-update)
            run_self_update
            ;;
        claude|code)
            shift
            wrap_claude "$@"
            ;;
        proxy)
            shift
            exec headroom proxy "$@"
            ;;
        rtk)
            shift
            exec rtk "$@"
            ;;
        *)
            unknown_cmd "$1"
            ;;
    esac
}

main "$@"
